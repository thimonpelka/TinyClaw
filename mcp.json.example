{
  "mcpServers": {
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "your GitHub PAT"
      }
    }
  },
  "tinyclaw": {
    "token_ttl": {
      "github": "forever"
    }
  }
}
